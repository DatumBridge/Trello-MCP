# Trello MCP Configuration

PORT=8000
LOG_LEVEL=INFO

# Trello Power-Up API credentials (set at MCP deployment — not on datumbridge-mcp)
TRELLO_API_KEY=
TRELLO_API_SECRET=

# Where Studio redirects after Connect (Integrations page base URL — match Studio NodePort/ingress)
STUDIO_PUBLIC_URL=http://localhost:30080

# OAuth callback (register in Trello Power-Up admin) — via Studio /api/mcp → datumbridge-mcp → trello-mcp
OAUTH_REDIRECT_URI=http://localhost:30080/api/mcp/api/v1/credentials/oauth/trello/callback

# Credential vault (datumbridge-mcp) — cross-namespace in K8s (trello-mcp in mcp-tools)
CREDENTIAL_VAULT_API_URL=http://datumbridge-mcp.datumbridge-adk-db.svc.cluster.local:8081
# DATUMBRIDGE_MCP_NAMESPACE=datumbridge-adk-db
# DATUMBRIDGE_MCP_SERVICE=datumbridge-mcp
# DATUMBRIDGE_MCP_PORT=8081
MCP_SERVICE_API_KEY=

# Outbound HTTP timeout (seconds). Default 30.
TRELLO_HTTP_TIMEOUT_SEC=30

# Path jail for credentials_path (defaults to project root)
# TRELLO_CREDENTIALS_DIR=/var/trello-credentials
