# Trello MCP Configuration

PORT=8000
LOG_LEVEL=INFO

# Trello Power-Up API credentials (set at MCP deployment — not on datumbridge-mcp)
TRELLO_API_KEY=
TRELLO_API_SECRET=

# Where Studio redirects after Connect (Integrations page base URL)
STUDIO_PUBLIC_URL=http://localhost:5173

# OAuth callback registered in Trello Power-Up admin (defaults to TRELLO_MCP_PUBLIC_URL/oauth/callback)
# OAUTH_REDIRECT_URI=http://127.0.0.1:30081/oauth/callback
# TRELLO_MCP_PUBLIC_URL=http://127.0.0.1:30081

# Credential vault (datumbridge-mcp) — service-to-service save after OAuth
CREDENTIAL_VAULT_API_URL=http://datumbridge-mcp:8081
MCP_SERVICE_API_KEY=

# Outbound HTTP timeout (seconds). Default 30.
TRELLO_HTTP_TIMEOUT_SEC=30

# Path jail for credentials_path (defaults to project root)
# TRELLO_CREDENTIALS_DIR=/var/trello-credentials
